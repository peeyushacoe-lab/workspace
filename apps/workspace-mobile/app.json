{
  "expo": {
    "name": "Nexus",
    "slug": "nexus-cybersage",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cybersage",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1321"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uk.cybersage.workspace",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Nexus uses your camera to join video meetings and attach photos to messages and email.",
        "NSPhotoLibraryUsageDescription": "Nexus needs access to your photo library to attach images to emails, chat messages, and Drive.",
        "NSMicrophoneUsageDescription": "Nexus uses your microphone for voice and video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0f1321"
      },
      "package": "uk.cybersage.workspace",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00C2FF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
