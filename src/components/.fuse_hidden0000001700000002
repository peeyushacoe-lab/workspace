type LoginAnomaly = {
  email: string;
  count: number;
  firstAttempt: string;
  lastAttempt: string;
  userId: string | null;
};

type DlpTrend = { date: string; count: number };

type SecurityStats = {
  failedLogins24h: number;
  failedLogins7d: number;
  activeSessions: number;
  usersOnHold: number;
  topFailedLogins: { email: string; count: number }[];
  loginAnomalies: LoginAnomaly[];
  noSuccessUsers: { email: string; count: number }[];
  dlpTrends: DlpTrend[];
};

