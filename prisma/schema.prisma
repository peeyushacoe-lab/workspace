// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
}

enum EmailStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum EmailTemplate {
  ACCEPTED
  REJECTED
  INTERVIEW
  REMINDER
  CUSTOM
}

enum UserRole {
  // System
  ADMIN

  // Key leadership (one of each — enforced in API)
  CEO
  CISO
  R_AND_D
  COO
  OPS_MANAGER

  // Team members
  DEVELOPER
  CYBER_SECURITY
  QA
  MARKETING
  RESEARCH
  FINANCE
  OPERATIONS
  SUPPORT

  // Dedicated HR account
  HR

  INTERNSHIP

  // Neutral baseline — custom-role-only users hold MEMBER; grants nothing on its own.
  // Real access comes from UserRoleAssignment (see RFC-001).
  MEMBER
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  fullName        String
  role            UserRole @default(ADMIN)
  customRole      String?
  // Multi-tenant
  organizationId  String?
  orgRole         String?  @default("MEMBER") // OWNER, ADMIN, MEMBER, GUEST
  // RBAC (RFC-001): bumped whenever this user's effective permissions change,
  // so the signed session cookie can be detected as stale and silently refreshed.
  permEpoch       Int      @default(0)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  avatarUrl       String?
  coverUrl        String?
  isActive          Boolean  @default(true)
  mustResetPassword Boolean  @default(false)
  hasCompletedTour  Boolean  @default(false)
  personalEmail     String?
  invitedBy         String?
  mfaEnabled        Boolean  @default(false)
  mfaSecret         String?
  mfaBackupCodes    String[] @default([])
  // Profile fields
  displayName       String?
  bio               String?
  jobTitle          String?
  company           String?
  department        String?
  phone             String?
  website           String?
  location          String?
  timezone          String?  @default("UTC")
  language          String?  @default("en")
  pronouns          String?
  birthday          DateTime?
  statusMessage     String?
  statusEmoji       String?
  // Persisted preferences (JSON blob — flexible, no extra migrations needed)
  preferences       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  mailboxes         MailboxAccess[]
  presence          UserPresence?
  riskScore         Int?
  riskLevel         String?
  lastRiskSync      DateTime?
  ssoProvider       String?
  ssoSubject        String?
  signature         Signature?
  emailTemplates    SavedEmailTemplate[]
  vacationResponder VacationResponder?
  loginEvents       LoginEvent[]
  emailLogs         EmailLog[]
  chatMemberships   ChatMember[]
  chatMessages      ChatMessage[]
  chatReactions     ChatReaction[]
  driveFolders      DriveFolder[]
  driveFiles        DriveFile[]
  calendarEvents    CalendarEvent[]    @relation("EventOrganizer")
  eventAttendances  EventAttendee[]    @relation("AttendeeUser")
  aiInteractions    AIInteraction[]
  aiMemories        AIMemory[]
  assignedIncidents SecurityIncident[] @relation("IncidentAssignee")
  notifications     Notification[]
  userSessions      UserSession[]
  notes             Note[]
  drafts            Draft[]
  meetings          Meeting[]          @relation("MeetingOrganizer")
  meetingParticipations MeetingParticipant[]
  legalHolds        LegalHold[]        @relation("LegalHoldUser")
  legalHoldsPlaced  LegalHold[]        @relation("LegalHoldPlacedBy")
  mobilePushTokens  MobilePushToken[]
  passkeys          Passkey[]

  // Internship Hub relations
  internAnnouncements  InternAnnouncement[]   @relation("AnnouncementAuthor")
  internTasksCreated   InternTask[]           @relation("InternTaskCreator")
  internSubmissions    InternSubmission[]     @relation("InternSubmitter")
  internDiscussions    InternDiscussion[]     @relation("DiscussionAuthor")
  internFindings       InternFinding[]        @relation("FindingSubmitter")
  internReviews        InternReview[]         @relation("InternReviewer")
  internReactions      InternReaction[]       @relation("InternReactionUser")
  internComments       InternComment[]        @relation("InternCommentAuthor")
  // Learning Weeks
  internWeeksCreated   InternWeek[]           @relation("WeekCreator")
  internWeeksUnlocked  InternWeek[]           @relation("WeekUnlocker")
  internWeekCompletions InternWeekCompletion[] @relation("WeekCompletions")
  internWeekNotes      InternWeekMentorNote[] @relation("WeekMentorNotes")
  internModuleCompletions InternModuleCompletion[] @relation("ModuleCompletions")
  // HR suite
  leaveRequests       LeaveRequest[]       @relation("LeaveRequester")
  leaveReviews        LeaveRequest[]       @relation("LeaveReviewer")
  hrDocuments         HRDocument[]         @relation("HRDocOwner")
  hrDocsUploaded      HRDocument[]         @relation("HRDocUploader")
  onboardingItems     OnboardingItem[]     @relation("OnboardingOwner")
  onboardingCreated   OnboardingItem[]     @relation("OnboardingCreator")
  // Mentor workspace
  mentorAssignments   MentorAssignment[]   @relation("AssignmentMentor")
  internAssignment    MentorAssignment?    @relation("AssignmentIntern")
  evaluationsReceived InternEvaluation[]   @relation("EvalIntern")
  evaluationsGiven    InternEvaluation[]   @relation("EvalMentor")
  mentorNotesGiven    MentorNote[]         @relation("MentorNoteAuthor")
  mentorNotesReceived MentorNote[]         @relation("MentorNoteIntern")
  certificates        InternCertificate[]  @relation("CertIntern")
  certificatesIssued  InternCertificate[]  @relation("CertIssuer")
  // Team challenges
  challengesCreated    Challenge[]          @relation("ChallengeCreator")
  challengeTeamsLed    ChallengeTeam[]      @relation("ChallengeTeamLead")
  challengeScoresGiven ChallengeScore[]     @relation("ChallengeScorer")
  challengeSubmissions ChallengeSubmission[] @relation("ChallengeSubmitter")

  // RBAC + org hierarchy (RFC-001)
  roleAssignments      UserRoleAssignment[]     @relation("AssignmentUser")
  permissionOverrides  UserPermissionOverride[] @relation("OverrideUser")
  teamMemberships      TeamMember[]             @relation("TeamMemberUser")

  // Tasks & Work Management (RFC-002)
  taskLists          TaskList[]       @relation("TaskListOwner")
  tasksCreated       Task[]           @relation("TaskCreator")
  taskAssignments    TaskAssignee[]   @relation("TaskAssigneeUser")
  taskComments       TaskComment[]    @relation("TaskCommentAuthor")
  taskAttachments    TaskAttachment[] @relation("TaskAttachmentUploader")
}

// WebAuthn passkey credentials
model Passkey {
  id           String    @id @default(cuid())
  userId       String
  name         String    @default("My passkey")
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String    // "singleDevice" | "multiDevice"
  backedUp     Boolean   @default(false)
  transports   String[]
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Admin-defined custom roles (supplements UserRole enum)
model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSingleton Boolean  @default(false) // true = only one user may hold this role
  color       String?  // hex for UI badge
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Dynamic RBAC (RFC-001) ───────────────────────────────────────────────────
// Role → Permissions, User → Role(s). Replaces hardcoded role logic.
// NOTE: the permission-catalog model is named `PermissionDef` for now to avoid
// a name collision with the legacy per-user `Permission` model (dropped in the
// final cleanup PR, at which point PermissionDef is renamed to Permission).

model Role {
  id             String   @id @default(cuid())
  organizationId String?  // null = global/system role template (seeded from UserRole enum)
  key            String   // stable slug, e.g. "developer", "ciso"
  name           String   // display name
  description    String?
  color          String?
  isSystem       Boolean  @default(false) // seeded, cannot be deleted
  isSingleton    Boolean  @default(false) // only one holder (CEO, CISO, …)
  rank           Int      @default(100)   // lower = more privileged; used for "can't manage a higher role"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  assignments  UserRoleAssignment[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model PermissionDef {
  id          String   @id @default(cuid())
  key         String   @unique // "email.read", "drive.delete", "hr.manage"
  resource    String   // "email", "drive", "hr"
  action      String   // "read", "delete", "manage"
  label       String   // human label for the admin UI
  description String?
  category    String   // grouping in the UI: "Workspace", "Security", "Admin"
  isDangerous Boolean  @default(false) // require extra confirmation to grant

  roles     RolePermission[]
  overrides UserPermissionOverride[]

  @@index([resource])
  @@index([category])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   PermissionDef @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  scopeType String?  // null = org-wide; reserved for "department" | "team" (deferred)
  scopeId   String?
  createdAt DateTime @default(now())

  user User @relation("AssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([roleId])
}

model UserPermissionOverride {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  granted      Boolean  // true = extra grant, false = explicit deny (deny wins)
  grantedBy    String?
  reason       String?
  createdAt    DateTime @default(now())

  user       User          @relation("OverrideUser", fields: [userId], references: [id], onDelete: Cascade)
  permission PermissionDef @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
}

// ─── Org hierarchy (RFC-001) ──────────────────────────────────────────────────

model Department {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  managerId      String?  // a User who heads the department
  parentId       String?  // optional nesting (Security > SOC)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Department?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Department[] @relation("DeptTree")
  teams        Team[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  departmentId   String?
  name           String
  slug           String
  icon           String?
  color          String?
  managerId      String?
  isSystem       Boolean  @default(false) // seeded from DEFAULT_TEAMS
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  members      TeamMember[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([departmentId])
}

model TeamMember {
  teamId   String
  userId   String
  isLead   Boolean  @default(false)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation("TeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Signature {
  id          String   @id @default(cuid())
  userId      String   @unique
  fullName    String
  title       String
  phone       String?
  linkedinUrl String?
  website     String?
  html        String
  plainText   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedEmailTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_email_templates")
  @@index([userId])
}

model VacationResponder {
  id        String    @id @default(cuid())
  userId    String    @unique
  isEnabled Boolean   @default(false)
  subject   String    @default("Automatic reply")
  message   String    @default("")
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VacationAutoReplyLog {
  id          String   @id @default(cuid())
  userId      String
  senderEmail String
  sentAt      DateTime @default(now())

  @@unique([userId, senderEmail])
  @@index([userId])
}

model Mailbox {
  id             String     @id @default(cuid())
  email          String     @unique
  displayName    String
  isShared       Boolean    @default(false)
  isNoReply      Boolean    @default(false)
  allowedRoles   UserRole[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  accessLogs   MailboxAccess[]
  threads      InboxThread[]
  folders      MailFolder[]
  importJobs   MailImportJob[]

  @@index([organizationId])
}

model MailboxAccess {
  id          String   @id @default(cuid())
  mailboxId   String
  userId      String
  role        String   @default("VIEWER") // OWNER, EDITOR, VIEWER
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mailbox     Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mailboxId, userId])
  @@index([userId])
}

enum ThreadPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model MailFolder {
  id        String   @id @default(cuid())
  userId    String
  mailboxId String?
  name      String
  color     String?
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mailbox Mailbox?      @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  threads InboxThread[]

  @@index([userId])
  @@index([mailboxId])
}

enum MailRuleAction {
  LABEL
  MOVE_FOLDER
  MARK_READ
  STAR
  ARCHIVE
  TRASH
  FORWARD
  PRIORITY
}

model MailRule {
  id         String         @id @default(cuid())
  userId     String
  name       String
  isActive   Boolean        @default(true)
  priority   Int            @default(0)
  // Conditions (JSON): [{field: "from"|"to"|"subject"|"body", op: "contains"|"equals"|"startsWith", value: "..."}]
  conditions Json
  action     MailRuleAction
  // Action params: folder id, label name, forward address, priority level, etc.
  actionData Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId, isActive])
}

model ScheduledEmail {
  id          String    @id @default(cuid())
  userId      String
  scheduledAt DateTime
  sentAt      DateTime?
  subject     String
  body        String
  toAddresses String[]
  ccAddresses String[]  @default([])
  bccAddresses String[] @default([])
  fromEmail   String
  signatureId String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([scheduledAt, sentAt])
}

model InboxThread {
  id           String          @id @default(cuid())
  subject      String
  mailboxId    String
  mailbox      Mailbox         @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  folderId     String?
  folder       MailFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  isStarred    Boolean         @default(false)
  isArchived   Boolean         @default(false)
  isTrashed    Boolean         @default(false)
  isSnoozed    Boolean         @default(false)
  snoozedUntil DateTime?
  isSpam       Boolean         @default(false)
  spamReportedAt DateTime?
  priority     ThreadPriority  @default(NORMAL)
  labels       String[]        @default([])
  // Shared mailbox fields
  assignedToId String?
  slaDeadline  DateTime?
  isLocked     Boolean         @default(false)
  lockedBy     String?
  lockedAt     DateTime?
  // Internal notes for shared mailboxes
  internalNote String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt

  messages InboxMessage[]

  @@index([mailboxId])
  @@index([mailboxId, createdAt])
  @@index([mailboxId, isStarred])
  @@index([mailboxId, isArchived])
  @@index([mailboxId, isTrashed])
  @@index([mailboxId, isSnoozed])
  @@index([mailboxId, isSpam])
  @@index([folderId])
  @@index([assignedToId])
}

model Draft {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  to          String   @default("")
  cc          String   @default("")
  bcc         String   @default("")
  subject     String   @default("")
  body        String   @default("")
  signatureId String?
  savedAt     DateTime @default(now()) @updatedAt

  @@index([userId, savedAt])
}

model InboxMessage {
  id          String      @id @default(cuid())
  threadId    String
  thread      InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  from        String
  to          String
  subject     String
  textBody    String?
  htmlBody    String?
  isRead      Boolean     @default(false)
  attachments EmailAttachment[]
  threatScan  ThreatScan?
  messageId   String?     @unique
  inReplyTo   String?
  references  String?
  receivedAt  DateTime    @default(now())

  @@index([threadId])
  @@index([isRead])
  @@index([threadId, receivedAt])
}

model EmailAttachment {
  id          String   @id @default(cuid())
  messageId   String
  message     InboxMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename    String
  mimeType    String
  size        Int      @default(0)
  storageUrl  String?
  key         String?
  bucket      String?
  // "SAFE" | "MACRO_RISK" | "ARCHIVE" | "DANGEROUS"
  threatVerdict String? @default("SAFE")
  isDangerous   Boolean @default(false)
  createdAt   DateTime @default(now())

  @@index([messageId])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  type      String
  severity  String
  userId    String?
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([type, severity])
}

model AuditLog {
  id             String   @id @default(cuid())
  actorId        String?
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  ipAddress      String?
  organizationId String?
  createdAt      DateTime @default(now())

  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
  @@index([organizationId])
  // Hot path: push-subscription lookups filter actorId + action="PUSH_SUBSCRIBE"
  // on every chat message / DM / inbound email / notification-worker run.
  @@index([actorId, action])
}

model ThreatScan {
  id          String   @id @default(cuid())
  messageId   String   @unique
  message     InboxMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  riskScore   Int
  findings    Json
  // "PASS" | "FAIL" | "NONE" | "UNKNOWN"
  spfResult   String?  @default("UNKNOWN")
  dkimResult  String?  @default("UNKNOWN")
  dmarcResult String?  @default("UNKNOWN")
  // "CLEAN" | "SUSPICIOUS" | "SPAM" | "PHISHING"
  verdict     String   @default("CLEAN")
  isFirstTimeSender Boolean @default(false)
  linksRewritten    Boolean @default(false)
  scannedAt   DateTime @default(now())

  @@index([verdict])
}

// Per-mailbox sender reputation — built from send history and user-reported
// spam/not-spam feedback. Consulted on every inbound message to bias the
// spam/phishing verdict without re-running expensive checks each time.
model SenderReputation {
  id           String   @id @default(cuid())
  mailboxId    String
  senderEmail  String
  senderDomain String
  firstSeenAt  DateTime @default(now())
  messageCount Int      @default(0)
  spamReports  Int      @default(0)
  hamReports   Int      @default(0)
  isBlocked    Boolean  @default(false)
  isTrusted    Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  @@unique([mailboxId, senderEmail])
  @@index([mailboxId, senderDomain])
}

model Contact {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  status    String
  metadata  Json?
  logs      EmailLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Campaign {
  id         String         @id @default(cuid())
  title      String
  template   EmailTemplate
  recipients Int            @default(0)
  sentCount  Int            @default(0)
  failCount  Int            @default(0)
  status     CampaignStatus @default(DRAFT)
  logs       EmailLog[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
}

model EmailLog {
  id                String      @id @default(cuid())
  recipient         String
  subject           String
  status            EmailStatus @default(PENDING)
  error             String?
  resendId          String?
  providerMessageId String?
  openedAt          DateTime?
  clickedAt         DateTime?
  bouncedAt         DateTime?
  contactId         String?
  campaignId        String?
  payload           Json?
  contact           Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaign          Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId            String?
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([campaignId])
  @@index([status])
  @@index([userId])
  @@index([recipient])
  @@index([resendId])
  // Deliverability dashboard: filter by status, sorted by recency.
  @@index([status, createdAt])
}

model SuppressionList {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String   // BOUNCE, SPAM, MANUAL
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Phase 3: Workspace Chat ──────────────────────────────────────────────────

enum ChatChannelType {
  CHANNEL
  DIRECT
  GROUP
}

enum PresenceStatus {
  ONLINE
  AWAY
  BUSY
  INVISIBLE
  OFFLINE
}

model UserPresence {
  id           String         @id @default(cuid())
  userId       String         @unique
  status       PresenceStatus @default(OFFLINE)
  statusMessage String?
  lastSeenAt   DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ChatChannel {
  id              String          @id @default(cuid())
  name            String
  description     String?
  type            ChatChannelType @default(CHANNEL)
  isPrivate       Boolean         @default(false)
  isBroadcast     Boolean         @default(false)
  createdById     String?
  pinnedMessageId String?
  topic           String?
  organizationId  String?
  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  members  ChatMember[]
  messages ChatMessage[]

  @@index([type])
  @@index([organizationId])
}

model ChatMember {
  id         String      @id @default(cuid())
  channelId  String
  userId     String
  role       String      @default("MEMBER")
  lastReadAt DateTime?
  joinedAt   DateTime    @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChatMessage {
  id               String    @id @default(cuid())
  channelId        String
  userId           String
  content          String
  editedAt         DateTime?
  deletedAt        DateTime?
  parentId         String?
  isPinned         Boolean   @default(false)
  pinnedAt         DateTime?
  mentionedUserIds String[]  @default([])
  // Voice note fields
  voiceNoteUrl     String?
  voiceNoteDuration Int?
  // File attachment
  attachmentUrl    String?
  attachmentName   String?
  attachmentMime   String?
  attachmentSize   Int?
  // Urgent/priority flag
  isUrgent         Boolean   @default(false)
  // Forwarded message
  forwardedFromId  String?
  forwardedFrom    ChatMessage?  @relation("ForwardedMessages", fields: [forwardedFromId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  forwards         ChatMessage[] @relation("ForwardedMessages")
  // Polls
  pollId           String?
  poll             ChatPoll?     @relation(fields: [pollId], references: [id], onDelete: SetNull)

  channel   ChatChannel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    ChatMessage?     @relation("ThreadReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   ChatMessage[]    @relation("ThreadReplies")
  reactions ChatReaction[]
  readBy    ChatMessageRead[]
  saved     SavedChatMessage[]
  createdAt DateTime         @default(now())

  @@index([channelId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@index([isPinned])
  @@index([forwardedFromId])
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model ChatMessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  channelId String
  readAt    DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([channelId, userId])
}

model SavedChatMessage {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  savedAt   DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, savedAt])
}

model ChatChannelDraft {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  content   String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([channelId, userId])
  @@index([userId])
}

model ChatPoll {
  id          String   @id @default(cuid())
  channelId   String
  createdById String
  question    String
  isMultiple  Boolean  @default(false)
  endsAt      DateTime?
  createdAt   DateTime @default(now())

  options  ChatPollOption[]
  messages ChatMessage[]

  @@index([channelId])
}

model ChatPollOption {
  id     String @id @default(cuid())
  pollId String
  text   String
  order  Int    @default(0)

  poll  ChatPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes ChatPollVote[]

  @@index([pollId])
}

model ChatPollVote {
  id       String   @id @default(cuid())
  optionId String
  userId   String
  votedAt  DateTime @default(now())

  option ChatPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([userId])
}

// ─── Phase 4: Drive / File Storage ───────────────────────────────────────────

model DriveFolder {
  id             String   @id @default(cuid())
  name           String
  parentId       String?
  ownerId        String
  isShared       Boolean  @default(false)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent      DriveFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    DriveFolder[] @relation("FolderTree")
  files       DriveFile[]
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  permissions DrivePermission[]

  @@index([ownerId])
  @@index([parentId])
}

model DriveFile {
  id             String    @id @default(cuid())
  name           String
  mimeType       String
  size           BigInt    @default(0)
  folderId       String?
  ownerId        String
  organizationId String?
  storageKey     String
  storageUrl     String?
  previewUrl     String?
  description    String?
  // File intelligence (Phase 4)
  ocrText        String?
  classification String?   // DOCUMENT, SPREADSHEET, PRESENTATION, IMAGE, CODE, ARCHIVE, OTHER
  aiSummary      String?
  isDuplicate    Boolean   @default(false)
  duplicateOfId  String?
  sensitivityLevel String? // PUBLIC, INTERNAL, CONFIDENTIAL, RESTRICTED
  isStarred      Boolean   @default(false)
  isTrashed      Boolean   @default(false)
  trashedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  folder      DriveFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  versions    DriveFileVersion[]
  permissions DrivePermission[]
  activities  DriveActivity[]

  @@index([ownerId])
  @@index([folderId])
  @@index([classification])
  // Main Drive list: owner's files filtered by trash flag, sorted by recency.
  @@index([ownerId, isTrashed, updatedAt])
  // Folder browsing filtered by trash flag.
  @@index([folderId, isTrashed])
}

model DriveActivity {
  id        String   @id @default(cuid())
  fileId    String
  userId    String
  action    String   // VIEW, DOWNLOAD, EDIT, SHARE, COMMENT, VERSION_RESTORE
  metadata  Json?
  createdAt DateTime @default(now())

  file DriveFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId, createdAt])
  @@index([userId])
}

model DriveFileVersion {
  id         String   @id @default(cuid())
  fileId     String
  versionNum Int      @default(1)
  storageKey String
  size       BigInt   @default(0)
  uploadedBy String
  createdAt  DateTime @default(now())

  file DriveFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

model DrivePermission {
  id        String    @id @default(cuid())
  fileId    String?
  folderId  String?
  userId    String?
  email     String?
  role      String    @default("VIEWER")
  token     String?   @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  file   DriveFile?   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder DriveFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([folderId])
  @@index([userId])
}

// ─── Phase 5: Calendar ────────────────────────────────────────────────────────

enum EventVisibility {
  PUBLIC
  PRIVATE
  TEAM
}

enum EventStatus {
  TENTATIVE
  CONFIRMED
  CANCELLED
}

enum AttendeeStatus {
  PENDING
  ACCEPTED
  DECLINED
  MAYBE
}

model CalendarEvent {
  id             String          @id @default(cuid())
  title          String
  description    String?
  location       String?
  startAt        DateTime
  endAt          DateTime
  allDay         Boolean         @default(false)
  timezone       String          @default("UTC")
  visibility     EventVisibility @default(PUBLIC)
  status         EventStatus     @default(CONFIRMED)
  isRecurring    Boolean         @default(false)
  recurrenceRule String?
  organizerId    String
  color          String?
  meetingUrl     String?
  organizationId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organizer User            @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  attendees EventAttendee[]
  reminders EventReminder[]

  @@index([organizerId])
  @@index([startAt, endAt])
  // Calendar visibility query scans all-users' PUBLIC events within a date range.
  @@index([visibility, startAt])
}

model EventAttendee {
  id      String         @id @default(cuid())
  eventId String
  userId  String?
  email   String
  name    String?
  status  AttendeeStatus @default(PENDING)

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User?         @relation("AttendeeUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([eventId, email])
  @@index([userId])
}

model EventReminder {
  id            String   @id @default(cuid())
  eventId       String
  minutesBefore Int
  method        String   @default("EMAIL")
  sent          Boolean  @default(false)

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([sent, eventId])
}

// ─── Phase 6: AI Interactions ─────────────────────────────────────────────────

model AIInteraction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  prompt    String
  response  String
  model     String   @default("gpt-4o-mini")
  tokens    Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // AI history / memory: per-user interactions fetched most-recent-first. High growth.
  @@index([userId, createdAt])
}

// ─── Phase 8: Notifications ───────────────────────────────────────────────────

enum NotificationType {
  MENTION
  CALENDAR_INVITE
  CALENDAR_REMINDER
  SOC_ALERT
  DLP_VIOLATION
  NEW_MESSAGE
  FILE_SHARED
  SYSTEM
  TASK_ASSIGNED
  TASK_DUE_SOON
  TASK_COMMENT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  // Notification hub: per-user feed sorted by recency (the default, non-unread query).
  @@index([userId, createdAt])
}

// ─── Phase 9: Session Management ─────────────────────────────────────────────

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  userAgent  String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Phase 7: Security Operations ────────────────────────────────────────────

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CONTAINED
  RESOLVED
  CLOSED
}

model SecurityIncident {
  id          String           @id @default(cuid())
  title       String
  description String
  severity    IncidentSeverity
  status      IncidentStatus   @default(OPEN)
  assignedTo  String?
  sourceType  String?
  sourceId    String?
  metadata    Json?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  assignee User?              @relation("IncidentAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  timeline IncidentTimeline[]

  @@index([status])
  @@index([severity])
}

model IncidentTimeline {
  id         String   @id @default(cuid())
  incidentId String
  userId     String?
  action     String
  note       String?
  createdAt  DateTime @default(now())

  incident SecurityIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([userId])
}

// ─── Compliance track: SOC 2 / GDPR / pen-test readiness ──────────────────────

model ComplianceControl {
  id          String   @id @default(cuid())
  category    String   // SOC2 | GDPR | PENTEST
  key         String   // stable slug within the category, e.g. "access-reviews"
  label       String
  description String?
  status      String   @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | DONE | NOT_APPLICABLE
  owner       String?
  notes       String?
  dueDate     DateTime?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([category, key])
  @@index([category])
}

// ─── Phase 9: Notes ───────────────────────────────────────────────────────────

model Note {
  id             String   @id @default(cuid())
  title          String
  content        String   @default("")
  userId         String
  pinned         Boolean  @default(false)
  color          String?
  folder         String?
  isDoc          Boolean  @default(false)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, pinned, updatedAt])
  @@index([organizationId])
}

// ─── Phase 5: Sage Meet ───────────────────────────────────────────────────────

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model Meeting {
  id            String        @id @default(cuid())
  title         String
  description   String?
  organizerId   String
  roomName      String        @unique
  status        MeetingStatus @default(SCHEDULED)
  scheduledAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  recordingUrl  String?
  transcriptUrl String?
  aiSummary     String?
  actionItems   String[]      @default([])
  maxParticipants Int         @default(50)
  isRecordingEnabled Boolean  @default(false)
  isTranscriptionEnabled Boolean @default(false)
  passcode      String?
  calendarEventId String?
  organizationId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  organizer    User                 @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]

  @@index([organizerId])
  @@index([status])
  @@index([scheduledAt])
  @@index([organizationId])
}

enum ParticipantRole {
  HOST
  PRESENTER
  PARTICIPANT
}

model MeetingParticipant {
  id          String          @id @default(cuid())
  meetingId   String
  userId      String
  role        ParticipantRole @default(PARTICIPANT)
  joinedAt    DateTime?
  leftAt      DateTime?
  duration    Int?            // seconds
  createdAt   DateTime        @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([userId])
}

// ─── Phase 6: AI Operating System ────────────────────────────────────────────

enum AIMemoryType {
  PREFERENCE
  PROJECT
  WORKFLOW
  CONTACT
  FACT
}

model AIMemory {
  id        String       @id @default(cuid())
  userId    String
  type      AIMemoryType @default(FACT)
  content   String
  context   String?
  // Embedding stored as serialised float array until pgvector is provisioned
  embedding Json?
  tags      String[]     @default([])
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId])
}

model AIAgent {
  id           String   @id @default(cuid())
  name         String
  description  String?
  type         String   // INBOX_TRIAGE, SCHEDULING, KNOWLEDGE, COMPLIANCE
  isActive     Boolean  @default(true)
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  runs AIAgentRun[]

  @@index([type, isActive])
}

model AIAgentRun {
  id        String   @id @default(cuid())
  agentId   String
  userId    String?
  input     Json
  output    Json?
  status    String   @default("PENDING") // PENDING, RUNNING, DONE, FAILED
  error     String?
  startedAt DateTime @default(now())
  endedAt   DateTime?

  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([userId])
  @@index([status])
}

// ─── Phase 7: Sentinel Alerts ─────────────────────────────────────────────────

model SentinelAlert {
  id           String   @id @default(cuid())
  alertType    String
  severity     String   // LOW, MEDIUM, HIGH, CRITICAL
  targetType   String   // email, file, chat, login, user
  targetId     String
  userId       String?
  description  String
  metadata     Json?
  acknowledged Boolean  @default(false)
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([severity, acknowledged])
  @@index([createdAt])
}

// ─── Phase 8: Enterprise Admin ────────────────────────────────────────────────

model SSOConfig {
  id            String   @id @default(cuid())
  provider      String   // SAML, OIDC, GOOGLE, MICROSOFT
  entityId      String?
  metadataUrl   String?
  metadataXml   String?
  clientId      String?
  clientSecret  String?
  callbackUrl   String?
  isActive      Boolean  @default(false)
  autoProvision Boolean  @default(true)
  defaultRole   UserRole @default(DEVELOPER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([provider, isActive])
}

model SCIMSync {
  id          String   @id @default(cuid())
  externalId  String   @unique
  userId      String?
  resourceType String  // User, Group
  lastSyncAt  DateTime @default(now())
  metadata    Json?

  @@index([externalId])
  @@index([userId])
}

model LegalHold {
  id          String    @id @default(cuid())
  userId      String
  placedById  String
  reason      String
  scope       String[]  @default([])  // email, drive, chat, notes
  isActive    Boolean   @default(true)
  placedAt    DateTime  @default(now())
  liftedAt    DateTime?
  expiresAt   DateTime?
  notes       String?

  user      User @relation("LegalHoldUser",     fields: [userId],    references: [id], onDelete: Cascade)
  placedBy  User @relation("LegalHoldPlacedBy", fields: [placedById], references: [id])

  @@index([userId, isActive])
  @@index([placedAt])
}

model RetentionPolicy {
  id              String   @id @default(cuid())
  name            String
  resourceType    String   // email, drive, chat, notes, audit_logs
  retentionDays   Int
  deleteAfterHold Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([resourceType, isActive])
}

// ─── Phase 8: Search Index ────────────────────────────────────────────────────

model SearchIndex {
  id           String   @id @default(cuid())
  resourceType String   // email, chat_message, file, note, doc, calendar_event
  resourceId   String
  userId       String?
  content      String
  metadata     Json?
  indexedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([resourceType, resourceId])
  @@index([resourceType])
  @@index([userId])
}

// ─── Phase 18: Multi-Tenant Architecture ─────────────────────────────────────

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique // URL-safe identifier, e.g. "cybersage"
  domain       String?  @unique // custom domain for SSO / mail routing
  plan         String   @default("FREE") // FREE, STARTER, PRO, ENTERPRISE
  maxUsers     Int      @default(50)
  isActive     Boolean  @default(true)
  logoUrl      String?
  brandColor   String?  // hex, e.g. "#00d2ff"
  billingEmail String?
  trialEndsAt  DateTime?
  settings     Json?    // feature flags, preferences, policies, etc.
  // RBAC (RFC-001): bumped on org-wide role/permission edits to invalidate
  // every member's session cookie in one shot.
  permEpoch    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  mailboxes   Mailbox[]
  channels    ChatChannel[]
  invites     OrganizationInvite[]
  roles       Role[]
  departments Department[]
  teams       Team[]

  @@index([slug])
  @@index([domain])
}

model OrganizationInvite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  orgRole        String    @default("MEMBER") // OWNER, ADMIN, MEMBER, GUEST
  invitedById    String
  token          String    @unique @default(cuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@index([organizationId])
}

model Permission {
  id        String   @id @default(cuid())
  userId    String
  resource  String   // email, drive, chat, meet, admin, sentinel, ai, calendar
  action    String   // read, write, delete, share, admin
  granted   Boolean  @default(true)
  grantedBy String?
  createdAt DateTime @default(now())

  @@unique([userId, resource, action])
  @@index([userId])
}

// ─── Phase 12: AI Memory / RAG ────────────────────────────────────────────────

model DocumentEmbedding {
  id           String   @id @default(cuid())
  resourceType String   // email, file, note, doc, chat_message
  resourceId   String
  userId       String?
  content      String   // the text chunk that was embedded
  // Stored as Float array — cosine similarity via raw SQL / pgvector
  embedding    Float[]
  metadata     Json?
  createdAt    DateTime @default(now())

  @@unique([resourceType, resourceId])
  @@index([resourceType])
  @@index([userId])
}

model WorkspaceKnowledge {
  id        String   @id @default(cuid())
  title     String
  content   String
  source    String   @default("manual")  // manual, ai_generated, imported
  category  String?
  tags      String[] @default([])
  embedding Float[]
  userId    String?
  isPublic  Boolean  @default(false)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([userId])
}

// ─── Phase 13: Automation Engine ─────────────────────────────────────────────

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowRunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

model Workflow {
  id             String         @id @default(cuid())
  name           String
  description    String?
  status         WorkflowStatus @default(DRAFT)
  // { type: "EMAIL_RECEIVED"|"FILE_UPLOADED"|"CHAT_MESSAGE"|"SCHEDULED"|"MANUAL", conditions: [...] }
  trigger        Json
  // [{ type: "SEND_EMAIL"|"CREATE_TASK"|"NOTIFY"|"AI_PROCESS"|"WEBHOOK", config: {...} }]
  actions        Json
  createdById    String
  runCount       Int            @default(0)
  lastRunAt      DateTime?
  isAIPowered    Boolean        @default(false)
  aiPrompt       String?
  organizationId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  runs WorkflowRun[]

  @@index([status])
  @@index([createdById])
  @@index([organizationId])
}

model WorkflowRun {
  id          String            @id @default(cuid())
  workflowId  String
  status      WorkflowRunStatus @default(QUEUED)
  triggerData Json?
  results     Json?
  error       String?
  startedAt   DateTime          @default(now())
  endedAt     DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
}

model ApprovalFlow {
  id           String    @id @default(cuid())
  title        String
  description  String?
  requesterId  String
  approverId   String
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  resourceType String?
  resourceId   String?
  metadata     Json?
  dueAt        DateTime?
  decidedAt    DateTime?
  note         String?
  createdAt    DateTime  @default(now())

  @@index([requesterId])
  @@index([approverId, status])
}

// ─── Phase 14: Sentinel Deep Integration ─────────────────────────────────────

model FileScan {
  id           String   @id @default(cuid())
  fileId       String   @unique
  status       String   @default("PENDING") // PENDING, SCANNING, CLEAN, INFECTED, ERROR
  engine       String   @default("internal")
  findings     Json?
  malwareNames String[] @default([])
  riskScore    Int      @default(0)
  scannedAt    DateTime @default(now())

  @@index([status])
}

model DLPPolicy {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  scope       String[] @default([])  // email, drive, chat
  // [{ type: "regex"|"keyword"|"pattern", value: "..." }]
  patterns    Json
  action      String   @default("ALERT")  // ALERT, BLOCK, QUARANTINE
  severity    String   @default("MEDIUM")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  violations DLPViolation[]

  @@index([isActive])
}

model DLPViolation {
  id           String    @id @default(cuid())
  policyId     String
  userId       String?
  resourceType String    // email, file, chat_message
  resourceId   String
  snippet      String?
  action       String    // ALERTED, BLOCKED, QUARANTINED
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  policy DLPPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([userId])
  @@index([resolved])
}

model DeviceRiskProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  deviceId    String?
  platform    String?
  riskScore   Int      @default(0)
  riskFactors Json?
  lastSeenAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([riskScore])
}

// ─── Phase 15: Real-Time Collaboration ───────────────────────────────────────

model DocSession {
  id           String   @id @default(cuid())
  documentId   String
  userId       String
  cursorColor  String?
  cursorName   String?
  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  @@index([documentId])
  @@index([userId])
}

model DocComment {
  id          String    @id @default(cuid())
  documentId  String
  userId      String
  content     String
  range       Json?     // { from: number, to: number } Tiptap position
  resolved    Boolean   @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent  DocComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies DocComment[] @relation("CommentThread")

  @@index([documentId])
  @@index([userId])
}

model DocSnapshot {
  id         String   @id @default(cuid())
  documentId String
  content    String   // Tiptap JSON snapshot
  version    Int      @default(1)
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([documentId, version])
}

// ─── Phase 16: Ecosystem Platform ────────────────────────────────────────────

model APIKey {
  id             String    @id @default(cuid())
  userId         String
  name           String
  keyHash        String    @unique
  keyPrefix      String    // first 8 chars — shown in UI
  scopes         String[]  @default([])
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  organizationId String?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([organizationId])
}

model WebhookEndpoint {
  id              String    @id @default(cuid())
  userId          String
  url             String
  secret          String?
  events          String[]  @default([])
  isActive        Boolean   @default(true)
  failCount       Int       @default(0)
  lastTriggeredAt DateTime?
  organizationId  String?
  createdAt       DateTime  @default(now())

  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([isActive])
  @@index([organizationId])
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  endpointId   String
  event        String
  payload      Json
  statusCode   Int?
  responseBody String?
  success      Boolean  @default(false)
  attemptedAt  DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([event])
}

// ─── Mobile Push Tokens ───────────────────────────────────────────────────────

model MobilePushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("unknown") // ios, android
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Phase 17: Observability ──────────────────────────────────────────────────

model MetricSnapshot {
  id         String   @id @default(cuid())
  name       String   // queue_depth, active_users, email_sent, api_latency_p99, etc.
  value      Float
  labels     Json?
  capturedAt DateTime @default(now())

  @@index([name, capturedAt])
}

model SystemHealthLog {
  id        String   @id @default(cuid())
  service   String   // api, worker, database, redis, s3, email
  status    String   // healthy, degraded, down
  latencyMs Int?
  error     String?
  checkedAt DateTime @default(now())

  @@index([service, checkedAt])
}

// ─── Sentinel Parallel: SIEM + Threat Intel ──────────────────────────────────

model ThreatIntelFeed {
  id          String    @id @default(cuid())
  type        String    // IP, DOMAIN, HASH, EMAIL, URL
  value       String
  confidence  Int       @default(50) // 0–100
  severity    String    @default("MEDIUM")
  source      String?
  description String?
  expiresAt   DateTime?
  hitCount    Int       @default(0)
  lastHitAt   DateTime?
  createdAt   DateTime  @default(now())

  @@unique([type, value])
  @@index([type])
  @@index([severity])
}

model SIEMEvent {
  id            String   @id @default(cuid())
  source        String   // email, drive, chat, auth, network, file
  eventType     String
  severity      String   @default("INFO")
  userId        String?
  ipAddress     String?
  metadata      Json?
  rawData       Json?
  correlationId String?
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([source, eventType])
  @@index([userId])
  @@index([createdAt])
  @@index([correlationId])
}

model DetectionRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  severity    String   @default("MEDIUM")
  // { conditions: [{field, op, value}], logic: "AND"|"OR" }
  logic       Json
  action      String   @default("ALERT")  // ALERT, BLOCK, QUARANTINE, ISOLATE
  category    String?  // PHISHING, MALWARE, EXFILTRATION, ANOMALY, BRUTE_FORCE
  hitCount    Int      @default(0)
  lastHitAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, severity])
  @@index([category])
}

model BehavioralBaseline {
  id              String   @id @default(cuid())
  userId          String   @unique
  avgEmailsPerDay Float    @default(0)
  avgFilesPerDay  Float    @default(0)
  avgLoginHour    Float    @default(9)
  commonIPs       String[] @default([])
  anomalyScore    Int      @default(0)
  lastUpdatedAt   DateTime @default(now())

  @@index([anomalyScore])
}

// ─── Brain Parallel: Multi-Agent + Knowledge Graph ───────────────────────────

enum AgentTaskStatus {
  PENDING
  RUNNING
  WAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

model AgentTask {
  id           String          @id @default(cuid())
  agentId      String?
  userId       String?
  title        String
  description  String?
  status       AgentTaskStatus @default(PENDING)
  priority     Int             @default(5)  // 1–10
  input        Json?
  output       Json?
  steps        Json?           // array of completed reasoning steps
  error        String?
  parentTaskId String?
  metadata     Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  parent   AgentTask?  @relation("TaskTree", fields: [parentTaskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children AgentTask[] @relation("TaskTree")

  @@index([userId])
  @@index([status])
  @@index([agentId])
}

model KnowledgeNode {
  id         String   @id @default(cuid())
  label      String
  type       String   // PERSON, CONCEPT, PROJECT, PROCESS, FACT, ENTITY
  content    String?
  embedding  Float[]
  properties Json?
  userId     String?
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sourceEdges KnowledgeEdge[] @relation("EdgeSource")
  targetEdges KnowledgeEdge[] @relation("EdgeTarget")

  @@index([type])
  @@index([userId])
}

model KnowledgeEdge {
  id           String   @id @default(cuid())
  sourceId     String
  targetId     String
  relationship String   // RELATES_TO, PART_OF, CREATED_BY, DEPENDS_ON, CONTRADICTS
  weight       Float    @default(1.0)
  metadata     Json?
  createdAt    DateTime @default(now())

  source KnowledgeNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target KnowledgeNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationship])
  @@index([sourceId])
  @@index([targetId])
}

model AgentOrchestration {
  id          String    @id @default(cuid())
  name        String
  description String?
  agentIds    String[]  @default([])
  objective   String
  status      String    @default("IDLE")  // IDLE, RUNNING, COMPLETED, FAILED
  plan        Json?
  results     Json?
  userId      String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([userId])
}

// ─── Internship Hub ──────────────────────────────────────────────────────────

model InternAnnouncement {
  id          String   @id @default(cuid())
  title       String
  body        String
  isPinned    Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reactions   InternReaction[]
  comments    InternComment[]

  @@index([authorId])
  @@index([createdAt])
}

model InternTask {
  id          String    @id @default(cuid())
  title       String
  description String
  priority    String    @default("medium") // low | medium | high | urgent
  deadline    DateTime?
  assigneeIds String[]  @default([])       // intern user IDs assigned
  skillTags   String[]  @default([])       // e.g. ["Networking", "SIEM", "Python"]
  attachments Json?                         // [{name, url, type}]
  weekId      String?                       // optional link to a learning week
  isClosed    Boolean   @default(false)     // mentor-stopped/closed — hidden from active work, kept for records
  closedAt    DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy   User             @relation("InternTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  submissions InternSubmission[]
  discussions InternDiscussion[]

  @@index([createdById])
  @@index([deadline])
}

model InternSubmission {
  id          String   @id @default(cuid())
  taskId      String
  submitterId String
  status      String   @default("submitted") // submitted | under_review | approved | rejected | revision_requested
  notes       String?
  files       Json?    // [{name, url, type, size}]
  links       String[] @default([])           // GitHub URLs etc.
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task        InternTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submitter   User          @relation("InternSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  reviews     InternReview[]

  @@index([taskId])
  @@index([submitterId])
  @@index([status])
}

model InternDiscussion {
  id         String   @id @default(cuid())
  taskId     String?  // null = general channel
  authorId   String
  body       String
  isPinned   Boolean  @default(false)
  parentId   String?  // for threaded replies
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  task       InternTask?       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author     User              @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent     InternDiscussion? @relation("DiscussionReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    InternDiscussion[] @relation("DiscussionReplies")
  reactions  InternReaction[]

  @@index([taskId])
  @@index([authorId])
  @@index([parentId])
}

model InternFinding {
  id          String   @id @default(cuid())
  type        String   // bug_report | feature_request | finding
  title       String
  description String
  severity    String?  @default("medium") // low | medium | high | critical
  status      String   @default("open")   // open | in_review | resolved | closed
  steps       String?  // steps to reproduce (bug)
  useCase     String?  // expected benefit (feature)
  attachments Json?    // [{name, url}]
  submitterId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submitter   User     @relation("FindingSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  comments    InternComment[]

  @@index([submitterId])
  @@index([type])
  @@index([status])
}

model InternReview {
  id           String   @id @default(cuid())
  submissionId String
  reviewerId   String
  verdict      String   // approved | rejected | revision_requested
  comment      String?
  score        Int?     // 0–100 optional
  createdAt    DateTime @default(now())

  submission   InternSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer     User             @relation("InternReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([reviewerId])
}

model InternReaction {
  id             String              @id @default(cuid())
  emoji          String
  userId         String
  announcementId String?
  discussionId   String?
  createdAt      DateTime            @default(now())

  user           User                @relation("InternReactionUser", fields: [userId], references: [id], onDelete: Cascade)
  announcement   InternAnnouncement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  discussion     InternDiscussion?   @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId, emoji])
  @@unique([userId, discussionId, emoji])
  @@index([userId])
}

model InternComment {
  id             String              @id @default(cuid())
  body           String
  authorId       String
  announcementId String?
  findingId      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  author         User                @relation("InternCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  announcement   InternAnnouncement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  finding        InternFinding?      @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([announcementId])
  @@index([findingId])
}

// ─── Internship Learning Weeks ────────────────────────────────────────────────

model InternWeek {
  id          String    @id @default(cuid())
  weekNumber  Int
  title       String
  overview    String
  isUnlocked  Boolean   @default(false)
  unlockedAt  DateTime?
  unlockedById String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy   User                   @relation("WeekCreator", fields: [createdById], references: [id], onDelete: Cascade)
  unlockedBy  User?                  @relation("WeekUnlocker", fields: [unlockedById], references: [id], onDelete: SetNull)
  topics      InternWeekTopic[]
  resources   InternWeekResource[]
  checkpoints InternWeekCheckpoint[]
  completions InternWeekCompletion[]
  mentorNotes InternWeekMentorNote[]

  @@unique([weekNumber])
  @@index([weekNumber])
}

model InternWeekTopic {
  id      String     @id @default(cuid())
  weekId  String
  title   String
  body    String     // markdown
  order   Int        @default(0)
  quiz    Json?      // { questions: [{ id, type: "mcq"|"text", prompt, options?: string[], answerIndex?: number }] }
  week    InternWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  completions InternModuleCompletion[]

  @@index([weekId])
}

model InternModuleCompletion {
  id        String   @id @default(cuid())
  topicId   String
  weekId    String
  internId  String
  answers   Json?    // intern's submitted answers, e.g. { [questionId]: number | string }
  score     Int?     // % correct on the MCQ portion (0–100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic     InternWeekTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  intern    User            @relation("ModuleCompletions", fields: [internId], references: [id], onDelete: Cascade)

  @@unique([topicId, internId])
  @@index([internId])
  @@index([weekId])
}

model InternWeekResource {
  id     String     @id @default(cuid())
  weekId String
  title  String
  url    String
  type   String     @default("link") // link | file | video
  order  Int        @default(0)
  week   InternWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@index([weekId])
}

model InternWeekCheckpoint {
  id           String     @id @default(cuid())
  weekId       String
  title        String
  description  String?
  linkedTaskId String?    // optional link to InternTask
  order        Int        @default(0)
  week         InternWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@index([weekId])
}

model InternWeekCompletion {
  id        String     @id @default(cuid())
  weekId    String
  internId  String
  createdAt DateTime   @default(now())
  week      InternWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  intern    User       @relation("WeekCompletions", fields: [internId], references: [id], onDelete: Cascade)

  @@unique([weekId, internId])
  @@index([internId])
}

model InternWeekMentorNote {
  id        String     @id @default(cuid())
  weekId    String
  authorId  String
  body      String
  createdAt DateTime   @default(now())
  week      InternWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  author    User       @relation("WeekMentorNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([weekId])
  @@index([authorId])
}

// ─── HR Suite ────────────────────────────────────────────────────────────────

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
  UNPAID
  WFH
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum HRDocCategory {
  CONTRACT
  OFFER_LETTER
  ID_DOCUMENT
  CERTIFICATE
  POLICY
  PAYSLIP
  OTHER
}

enum ChecklistKind {
  ONBOARDING
  OFFBOARDING
}

model LeaveRequest {
  id         String      @id @default(cuid())
  userId     String
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  days       Float
  reason     String?
  status     LeaveStatus @default(PENDING)
  reviewerId String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user     User  @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("LeaveReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status])
}

model CompanyHoliday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  createdAt DateTime @default(now())

  @@index([date])
}

model HRDocument {
  id           String        @id @default(cuid())
  userId       String
  uploadedById String?
  title        String
  category     HRDocCategory @default(OTHER)
  fileName     String
  storageKey   String
  mimeType     String
  size         Int
  createdAt    DateTime      @default(now())

  user       User  @relation("HRDocOwner", fields: [userId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("HRDocUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([userId])
}

model OnboardingItem {
  id          String        @id @default(cuid())
  userId      String
  kind        ChecklistKind @default(ONBOARDING)
  title       String
  description String?
  order       Int           @default(0)
  dueDate     DateTime?
  completedAt DateTime?
  createdById String?
  createdAt   DateTime      @default(now())

  user      User  @relation("OnboardingOwner", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("OnboardingCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, kind])
}

// ─── Mentor Workspace ────────────────────────────────────────────────────────

model MentorAssignment {
  id        String   @id @default(cuid())
  mentorId  String
  internId  String   @unique
  createdAt DateTime @default(now())

  mentor User @relation("AssignmentMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  intern User @relation("AssignmentIntern", fields: [internId], references: [id], onDelete: Cascade)

  @@index([mentorId])
}

model InternEvaluation {
  id           String   @id @default(cuid())
  internId     String
  mentorId     String
  period       String // e.g. "Week 4", "Midpoint", "Final"
  isFinal      Boolean  @default(false)
  scores       Json // { technical, communication, initiative, reliability, teamwork } each 1-5
  overall      Float
  strengths    String?
  improvements String?
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  intern User @relation("EvalIntern", fields: [internId], references: [id], onDelete: Cascade)
  mentor User @relation("EvalMentor", fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([internId])
}

model MentorNote {
  id          String   @id @default(cuid())
  mentorId    String
  internId    String
  meetingDate DateTime @default(now())
  note        String
  actionItems String?
  isPrivate   Boolean  @default(true) // true = mentors only; false = intern can see
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mentor User @relation("MentorNoteAuthor", fields: [mentorId], references: [id], onDelete: Cascade)
  intern User @relation("MentorNoteIntern", fields: [internId], references: [id], onDelete: Cascade)

  @@index([internId])
}

model InternCertificate {
  id         String   @id @default(cuid())
  internId   String
  issuedById String?
  title      String
  serial     String   @unique
  grade      String? // e.g. "Distinction", "Merit", "Pass"
  issuedAt   DateTime @default(now())

  intern   User  @relation("CertIntern", fields: [internId], references: [id], onDelete: Cascade)
  issuedBy User? @relation("CertIssuer", fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([internId])
}

// ─── Intern Team Challenges ──────────────────────────────────────────────────
// Reusable team-vs-team competition system (e.g. "Week 4: Red vs Blue").

model Challenge {
  id            String    @id @default(cuid())
  title         String
  description   String                        // overall brief / objective
  status        String    @default("upcoming") // upcoming | active | judging | completed | cancelled
  deadline      DateTime?
  scoringSchema Json                            // [{ key, label, maxPoints }] — categories, should sum to 100
  winnerTeamId  String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdBy   User                  @relation("ChallengeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  winnerTeam  ChallengeTeam?        @relation("ChallengeWinner", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  teams       ChallengeTeam[]       @relation("ChallengeTeams")
  scores      ChallengeScore[]
  submissions ChallengeSubmission[]

  @@index([createdById])
  @@index([status])
}

model ChallengeTeam {
  id          String   @id @default(cuid())
  challengeId String
  name        String                     // e.g. "Team Red"
  color       String?                    // e.g. "red" | "blue" — UI badge accent
  mission     String?                    // team-specific mission brief
  leadId      String?
  memberIds   String[] @default([])      // intern user IDs on this team
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge     Challenge             @relation("ChallengeTeams", fields: [challengeId], references: [id], onDelete: Cascade)
  lead          User?                 @relation("ChallengeTeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  scores        ChallengeScore[]
  submissions   ChallengeSubmission[]
  wonChallenges Challenge[]           @relation("ChallengeWinner")

  @@index([challengeId])
}

model ChallengeScore {
  id          String   @id @default(cuid())
  challengeId String
  teamId      String
  category    String                 // key matching a scoringSchema entry, e.g. "technical"
  points      Float
  maxPoints   Float
  comment     String?
  scoredById  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  team      ChallengeTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scoredBy  User          @relation("ChallengeScorer", fields: [scoredById], references: [id], onDelete: Cascade)

  @@unique([teamId, category])
  @@index([challengeId])
  @@index([teamId])
}

model ChallengeSubmission {
  id          String   @id @default(cuid())
  challengeId String
  teamId      String
  submitterId String
  notes       String?
  files       Json?                    // [{name, url, type, size}]
  links       String[] @default([])    // report / repo / doc links
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  team      ChallengeTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  submitter User          @relation("ChallengeSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@index([teamId])
}

// ─────────────────────────────────────────────────────────────────────────
// Mail Migration Wizard — import from Gmail / any IMAP provider
// ─────────────────────────────────────────────────────────────────────────

enum ImportProvider {
  GMAIL
  OUTLOOK
  YAHOO
  IMAP
}

enum ImportStatus {
  PENDING
  CONNECTING
  IMPORTING
  COMPLETED
  FAILED
  CANCELLED
}

model MailImportJob {
  id                String         @id @default(cuid())
  userId            String
  mailboxId         String
  mailbox           Mailbox        @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  provider          ImportProvider @default(IMAP)
  host              String
  port              Int            @default(993)
  secure            Boolean        @default(true)
  username          String
  // AES-256-GCM encrypted app password — never store plaintext. See src/lib/crypto-secret.ts
  encryptedPassword String
  // [{ source: "INBOX", target: "inbox" | "archive" | "custom", label: "Old Gmail" }]
  folderMapping     Json?
  status            ImportStatus   @default(PENDING)
  totalMessages     Int            @default(0)
  importedMessages  Int            @default(0)
  skippedMessages    Int            @default(0)
  failedMessages    Int            @default(0)
  currentFolder     String?
  // string[] of the most recent errors (capped in application code)
  errorLog          Json?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([mailboxId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────
// Account Export / Takeout — full-account export as a downloadable zip
// ─────────────────────────────────────────────────────────────────────────

enum ExportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ExportJob {
  id             String       @id @default(cuid())
  userId         String
  includeMail     Boolean     @default(true)
  includeDrive    Boolean     @default(true)
  includeDocs     Boolean     @default(true)
  includeContacts Boolean     @default(true)
  includeCalendar Boolean     @default(true)
  status         ExportStatus @default(PENDING)
  totalItems     Int          @default(0)
  processedItems Int          @default(0)
  currentStage   String?
  resultKey      String?
  resultSize     Int?
  // Signed download URLs expire — this is when the current one was issued,
  // so the UI knows when to ask the API to re-sign.
  errorLog       Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────
// Public status page — periodic health snapshots + restore-drill records
// ─────────────────────────────────────────────────────────────────────────

model SystemStatusPing {
  id         String   @id @default(cuid())
  checkedAt  DateTime @default(now())
  dbOk       Boolean
  redisOk    Boolean
  emailOk    Boolean
  overallOk  Boolean
  latencyMs  Int?

  @@index([checkedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Tasks & Work Management (RFC-002) — replaces the earlier Redis-backed
// /api/tasks prototype. See docs/rfc-002-tasks-work-management.md.
// ─────────────────────────────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TaskList {
  id             String   @id @default(cuid())
  name           String
  ownerId        String
  organizationId String?
  isTeamList     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner User   @relation("TaskListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([ownerId])
  @@index([organizationId])
}

model Task {
  id           String       @id @default(cuid())
  listId       String?
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  createdById  String
  labels       String[]     @default([])
  // RRULE-style recurrence string (e.g. "FREQ=WEEKLY;BYDAY=MO"); null = one-off task
  recurrence   String?
  parentTaskId String?
  // Where this task originated, for cross-feature integration (Calendar/Chat/AI)
  sourceType   String?      // "meeting" | "chat" | "email" | null
  sourceId     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  list        TaskList?        @relation(fields: [listId], references: [id], onDelete: SetNull)
  createdBy   User             @relation("TaskCreator", fields: [createdById], references: [id])
  parentTask  Task?            @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subTasks    Task[]           @relation("SubTasks")
  assignees   TaskAssignee[]
  comments    TaskComment[]
  attachments TaskAttachment[]

  @@index([listId])
  @@index([createdById])
  @@index([status])
  @@index([dueDate])
  @@index([parentTaskId])
}

model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskCommentAuthor", fields: [authorId], references: [id])

  @@index([taskId])
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  fileName     String
  storageKey   String
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([taskId])
}

model BackupVerification {
  id            String   @id @default(cuid())
  status        String   // PASSED | FAILED
  tablesVerified Int     @default(0)
  rowsVerified  Int      @default(0)
  backupTimestamp String?
  details       Json?
  error         String?
  testedAt      DateTime @default(now())

  @@index([testedAt])
}
