{
  "name": "cybersage-mail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:all": "concurrently -n \"next,worker\" -c \"blue,green\" \"next dev --turbopack\" \"tsx scripts/worker.ts\"",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
