    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "create-user": "tsx scripts/create-user.ts",
    "worker": "tsx scripts/worker.ts",
    "dashboard": "tsx scripts/dashboard.ts",
    "mcp": "cd mcp-server && npm start"
  },
